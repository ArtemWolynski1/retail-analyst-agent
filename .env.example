# Gemini API key from https://aistudio.google.com/apikey (free tier)
GOOGLE_API_KEY=

# Any GCP project you own. BigQuery jobs run under its quota; queries against
# the public dataset fall inside the monthly 1 TB free tier.
GOOGLE_CLOUD_PROJECT=

# Models are per-role so the guard can run cheaper than the analyst loop.
AGENT_MODEL=gemini-2.5-flash
GUARD_MODEL=gemini-2.5-flash
FALLBACK_MODEL=gemini-2.5-flash-lite

BQ_DATASET=bigquery-public-data.thelook_ecommerce

# Hard cost cap per query (bytes). 200 MB is ~40x the largest table scan here.
MAX_BYTES_BILLED=200000000
MAX_RESULT_ROWS=50

SQLITE_PATH=.data/agent.sqlite
